{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "projectRoot": "apps/mobile",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_METRO_WORKSPACE_ROOT": "1",
        "EXPO_NO_DOCTOR": "true",
        "TURBO_TELEMETRY_DISABLED": "1",
        "SKIP_POSTINSTALL": "1"
      }
    },
    "preview": {
      "projectRoot": "apps/mobile",
      "distribution": "internal",
      "env": {
        "EXPO_USE_METRO_WORKSPACE_ROOT": "1",
        "EXPO_NO_DOCTOR": "true",
        "TURBO_TELEMETRY_DISABLED": "1",
        "SKIP_POSTINSTALL": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "projectRoot": "apps/mobile",
      "autoIncrement": true,
      "env": {
        "EXPO_USE_METRO_WORKSPACE_ROOT": "1",
        "EXPO_NO_DOCTOR": "true",
        "SKIP_POSTINSTALL": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
